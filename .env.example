# UnionLabs Session Manager - Environment Configuration

# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/unionlabs.db

# Docker
DOCKER_SOCKET=/var/run/docker.sock
DEFAULT_SESSION_IMAGE=unionlabs/session:latest

# SSH Tunnel Configuration
SSH_SIMULATION_MODE=true
SSH_DEFAULT_KEY_PATH=~/.ssh/id_rsa
SSH_DEFAULT_PORT=22
SSH_CONNECTION_TIMEOUT=10000

# Session Configuration
SESSION_MAX_DURATION_MINUTES=480
SESSION_DEFAULT_DURATION_MINUTES=60
SESSION_CLEANUP_INTERVAL_MINUTES=5

# Port Allocation for VNC/SSH tunnels
PORT_RANGE_START=5900
PORT_RANGE_END=5999

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/session-manager.log
