  "description": "UnionLabs Testbed Session Manager - Docker-based testbed session orchestration with SSH tunneling and noVNC remote access",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
